# Wolf Trades — Marketing Site
# Copy to .env.local and fill in real values. Never commit .env.local.

# ---- Public site config ----
# Canonical site URL — used by metadataBase + future absolute links.
NEXT_PUBLIC_SITE_URL="https://wolftrades.com"

# ---- Analytics ----
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). If unset, GA4 is not loaded.
# Vercel Web Analytics is enabled automatically — no key needed.
NEXT_PUBLIC_GA_ID=""

# ---- Lead capture / Resend ----
# https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender (must be on a verified domain in Resend).
RESEND_FROM_EMAIL="Wolf Trades <noreply@wolftrades.com>"
# Where new-lead notifications are delivered.
RESEND_NOTIFY_EMAIL="roland@rwtrades.com"

# ---- Lead capture / Supabase ----
# Public URL — safe to expose to client.
NEXT_PUBLIC_SUPABASE_URL=""
# Anon key — only use if/when the marketing site needs client-side reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — server-only. Used by /api/lead to insert into `leads`.
# WARNING: never expose this to the browser. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=""
