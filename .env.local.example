# Wolf Trades — Marketing Site
# Copy to .env.local and fill in real values. Never commit .env.local.

# ---- Public site config ----
# Canonical site URL — used by metadataBase + future absolute links.
NEXT_PUBLIC_SITE_URL="https://wolftrades.com"

# ---- Analytics ----
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). If unset, GA4 is not loaded.
# Vercel Web Analytics is enabled automatically — no key needed.
NEXT_PUBLIC_GA_ID=""

# ---- Conversion pixels ----
# Meta (Facebook) Pixel ID. If unset, the Meta pixel is not loaded.
NEXT_PUBLIC_META_PIXEL_ID=""
# TikTok Pixel ID. If unset, the TikTok pixel is not loaded.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# ---- GHL checkout / Payment Links ----
# GHL-hosted order/payment links (Authorize.Net via GHL). Paste the full
# https://... URL for each tier. Discount codes (LAUNCH97, LAUNCH147) and the
# legacy-member discount are configured inside GHL — not here. GHL owns the
# payment lifecycle (it posts to the platform-side inbound webhook), so there is
# no payment webhook receiver in this repo. If unset, pricing CTAs fall back to
# the /wolfpack#pricing anchor.
GHL_WOLFPACK_MONTHLY_URL=""
GHL_WOLFPACK_ANNUAL_URL=""
GHL_PRO_MONTHLY_URL=""
GHL_PRO_ANNUAL_URL=""
GHL_LEGACY_PRO_URL=""

# ---- Lead capture / Resend ----
# https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender (must be on a verified domain in Resend).
RESEND_FROM_EMAIL="Wolf Trades <noreply@wolftrades.com>"
# Where new-lead notifications are delivered.
RESEND_NOTIFY_EMAIL="roland@rwtrades.com"

# ---- Lead capture / Supabase ----
# Public URL — safe to expose to client.
NEXT_PUBLIC_SUPABASE_URL=""
# Anon key — only use if/when the marketing site needs client-side reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — server-only. Used by /api/lead to insert into `leads`.
# WARNING: never expose this to the browser. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Lead capture / GoHighLevel ----
# GHL Inbound Webhook URL. Configure inside GHL: Workflows → trigger
# "Inbound Webhook" → copy the URL it generates here. The workflow maps the
# JSON payload to Contact fields, tags, pipeline stage. Pipeline routing is
# managed in the workflow, not in this codebase.
# Example: https://services.leadconnectorhq.com/hooks/<location>/webhook-trigger/<id>
GHL_WEBHOOK_URL=""
